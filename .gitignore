# .gitignore pour projet d'analyse de sentiment

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Data files (ne pas versionner les données)
data/raw/*.csv
data/raw/*.json
data/raw/*.txt
data/processed/*.csv

# Models (trop gros pour git)
models/**/*.h5
models/**/*.pkl
models/**/*.bin

# Logs
logs/
*.log
tensorboard/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak
*.cache

# Training outputs
checkpoints/
saved_models/

# Downloaded embeddings
embeddings/
*.vec
*.txt.gz

# Keep directory structure
!.gitkeep
